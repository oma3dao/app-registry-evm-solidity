import { ethers, network } from "hardhat";
import { createThirdwebClient, getContract } from "thirdweb";
import { ethers6Adapter } from "thirdweb/adapters/ethers6";

// We'll dynamically import ThirdwebSDK only when needed to avoid type errors
// This is a cleaner approach than trying to reconcile hardhat's ethers v6 with ThirdwebSDK's ethers v5 requirement

async function main() {
  const networkName = network.name;
  console.log(`Deploying to network: ${networkName}`);

  // Check if private key is loaded
  if (!process.env.PRIVATE_KEY) {
    throw new Error("Private key not found. Please check ~/.ssh/test-evm-deployment-key");
  }
  console.log("Private key loaded successfully");

  // Check if the '-usethirdwebsdk' flag is provided
  const useThirdwebSDK = process.argv.includes('-usethirdwebsdk');
  
  try {
    // Deploy the contract using hardhat's ethers
    const OMA3AppRegistry = await ethers.getContractFactory("OMA3AppRegistry");
    const registry = await OMA3AppRegistry.deploy();
    await registry.waitForDeployment();

    const address = await registry.getAddress();
    console.log(`OMA3AppRegistry deployed to: ${address}`);

    // Wait for block confirmations
    console.log("Waiting for block confirmations...");
    await registry.deploymentTransaction()?.wait(5);
    
    // Verify contract using ThirdwebSDK if flag is provided
    if (useThirdwebSDK) {
      console.log("Flag -usethirdwebsdk detected. Using ThirdwebSDK v5 for verification...");
      
      try {
        // Initialize ThirdwebSDK client
        const client = createThirdwebClient({
          clientId: process.env.THIRDWEB_CLIENT_ID || "your-client-id", // Use your client ID
        });

        console.log("Getting contract with ThirdwebSDK...");
        const contract = await getContract({
          client,
          chain: networkName, // Use the network name as chain ID
          address,
        });
        
        console.log("Contract retrieved successfully!");
        console.log("Contract address:", address);
        
        // For ThirdwebSDK v5, you would typically use a different verification approach
        // This is a placeholder for Thirdweb v5's verification process
        console.log("");
        console.log("For ThirdwebSDK v5 verification, follow these steps:");
        console.log("1. Install the thirdweb CLI: npm install -g @thirdweb-dev/cli");
        console.log(`2. Run: npx thirdweb publish --contract ${address} --chain ${networkName}`);
        
      } catch (error) {
        console.error("Error with ThirdwebSDK:", error);
      }
    } else {
      console.log("Deployment completed successfully!");
      console.log("Contract address:", address);
      console.log("");
      console.log("If you want to verify your contract on Etherscan or another block explorer:");
      console.log(`1. Use standard hardhat verify: npx hardhat verify --network ${networkName} ${address}`);
      console.log("2. Or use ThirdwebSDK by rerunning with: npx hardhat run scripts/deploy.ts --network <network> -- -usethirdwebsdk");
    }

  } catch (error) {
    console.error("Deployment failed:", error);
    throw error;
  }
}

main()
  .then(() => process.exit(0))
  .catch((error) => {
    console.error(error);
    process.exit(1);
  }); 