# OMA3 App Registry Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DEPLOYMENT CONFIGURATION  
# =============================================================================

# ⚠️ DEVELOPMENT vs PRODUCTION DEPLOYMENT
#
# FOR DEVELOPMENT/TESTING:
# Use the npm scripts in this repository with a test private key
# 
# FOR PRODUCTION:
# Use Thirdweb Dashboard for secure deployment: https://thirdweb.com/contracts/deploy
# Benefits: Eliminates supply chain risks, hardware wallet support, secure infrastructure


# =============================================================================
# DEVELOPMENT/TESTING
# =============================================================================

# Enable gas reporting during tests
# Set to any value to enable gas reporting
# Example: REPORT_GAS=true
# REPORT_GAS=

# Explorer verification (Celoscan/Etherscan-compatible)
# Get an API key from https://alfajores.celoscan.io/myapikey
# CELOSCAN_API_KEY=

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. NEVER commit your actual .env file to version control
# 2. Development private keys are loaded from ~/.ssh/test-evm-deployment-key
# 3. Use test keys only - never use real funds for development
# 4. For production: Use Thirdweb Dashboard with hardware wallet support
# 5. Contract addresses are configured in hardhat.config.ts NETWORK_CONTRACTS
# 6. This module supports multiple networks: thirdwebTestnet, celoAlfajores, hardhat, localhost
#
# =============================================================================

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
#
# This module is configured to work with the following networks:
# - thirdwebTestnet (Chain ID: 894538)
# - celoAlfajores (Chain ID: 44787) 
# - hardhat (Chain ID: 31337) - Local development
# - localhost (Chain ID: 31337) - Local node
#
# Network-specific contract addresses are managed in hardhat.config.ts
# =============================================================================
