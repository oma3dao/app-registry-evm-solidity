# OMA3 App Registry Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# =============================================================================
# SIGNING CONFIGURATION (Choose one method)
# =============================================================================

# DEFAULT: Use Ledger hardware wallet for deployment (RECOMMENDED)
# This is the secure, production-ready approach for all deployments
# Set to "false" only for development/testing environments
USE_LEDGER=true

# FALLBACK: Private keys are loaded from ~/.ssh/test-evm-deployment-key file
# This is only used when USE_LEDGER=false
# The PRIVATE_KEY environment variable is used as a fallback
# WARNING: Less secure than hardware wallet deployment

# =============================================================================
# DEVELOPMENT/TESTING
# =============================================================================

# Enable gas reporting during tests
# Set to any value to enable gas reporting
# REPORT_GAS=true

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. NEVER commit your actual .env file to version control
# 2. USE_LEDGER=true is STRONGLY RECOMMENDED for all deployments
# 3. Hardware wallets provide enhanced security by keeping private keys offline
# 4. Private key fallback should only be used for development/testing
# 5. For Ledger setup: Connect device, unlock, and open Ethereum app
# 6. Contract addresses are configured in hardhat.config.ts NETWORK_CONTRACTS
#
# =============================================================================

# =============================================================================
# LEDGER SETUP INSTRUCTIONS
# =============================================================================
#
# To use Ledger hardware wallet (USE_LEDGER=true):
# 1. Connect your Ledger device via USB
# 2. Unlock the device with your PIN
# 3. Open the Ethereum app on your Ledger
# 4. Ensure browser support is disabled in Ledger Live
# 5. Run deployment command - device will prompt for confirmation
#
# Troubleshooting:
# - If connection fails, try reconnecting the USB cable
# - Ensure Ledger Live is closed during deployment
# - Check that the Ethereum app is the latest version
# - On Linux, you may need to add udev rules for Ledger devices
#
# =============================================================================
